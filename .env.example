# Supabase — public values, exposed to browser via NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — service role, NEVER exposed client-side. Used in API routes only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude — server-side only.
ANTHROPIC_API_KEY=sk-ant-your-key

# Single admin user email. Authenticated users with this exact email
# get access to /admin and /api/admin/*. Server-side only.
ADMIN_EMAIL=vishalvishvakarma1994+1@gmail.com

# Transactional email (Resend). Leave RESEND_API_KEY blank in dev/CI to
# skip real sends — the helper logs a dry-run instead.
RESEND_API_KEY=
EMAIL_FROM="Gumtree UK <no-reply@example.com>"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron auth token. Vercel sends this in the Authorization header.
# Leave blank locally to allow unauthenticated cron hits.
CRON_SECRET=
